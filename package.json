{
  "name": "@rabesss/cline-pass-extension",
  "version": "0.2.3",
  "description": "Dependency-free Pi and OMP provider extension for Cline Pass.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/rabesss/cline-pass-extension#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rabesss/cline-pass-extension.git"
  },
  "bugs": {
    "url": "https://github.com/rabesss/cline-pass-extension/issues"
  },
  "keywords": [
    "cline",
    "cline-pass",
    "omp-plugin",
    "omp-extension",
    "pi-package",
    "pi-extension",
    "provider"
  ],
  "exports": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && node --test",
    "test": "node --test"
  },
